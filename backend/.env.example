# =============================================
# VARIÁVEIS DE AMBIENTE OBRIGATÓRIAS - Freelamz
# =============================================
# Copiar este ficheiro para .env e preencher os valores reais
# NUNCA commitar o ficheiro .env para o repositório!

# Base de Dados (Railway Postgres)
DATABASE_URL=postgresql://usuario:senha@host:5432/freelamz

# JWT - OBRIGATÓRIO (mínimo 32 caracteres aleatórios)
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=GERAR_TOKEN_ALEATORIO_AQUI

# Admin (email do administrador da plataforma)
ADMIN_EMAIL=email_admin@dominio.com

# Gmail (para envio de emails)
GMAIL_USER=email@gmail.com
GMAIL_PASS=senha_de_app_gmail

# Frontend URL (para links em emails)
FRONTEND_URL=https://freelamz-frontend.vercel.app

# Porta (Railway define automaticamente)
PORT=5000
